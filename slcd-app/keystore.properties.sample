# ── قالب توقيع الإصدار (release) المحلي ─────────────────────────────
#
# انسخ هذا الملف باسم "keystore.properties" (بجانبه، في نفس مجلد
# slcd-app/) واملأ القيم الحقيقية. ملف "keystore.properties" نفسه
# مُستثنى من Git عبر .gitignore الجذري — لا تُزل هذا الاستثناء ولا
# تحاول رفع الملف أو الـ keystore يدوياً.
#
# ملاحظة: في CI (GitHub Actions) لا حاجة لهذا الملف إطلاقاً — التوقيع
# هناك يعتمد على أسرار الريبو (SLCD_KEYSTORE_FILE إلخ) المُمرَّرة عبر
# متغيرات بيئة APP_KEYSTORE_* في build_SLCD.yml، ولها الأولوية دائماً
# إن وُجدت.

# المسار الكامل (أو النسبي من slcd-app/) لملف الـ keystore نفسه:
storeFile=/path/to/your/release.keystore

# كلمة مرور الـ keystore:
storePassword=CHANGE_ME

# اسم الـ alias الخاص بمفتاح التوقيع داخل الـ keystore:
keyAlias=CHANGE_ME

# كلمة مرور المفتاح (قد تكون نفس storePassword حسب كيفية إنشاء الـ keystore):
keyPassword=CHANGE_ME
